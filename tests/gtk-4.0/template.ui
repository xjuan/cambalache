<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name template.ui -->
  <requires lib="gtk" version="4.0"/>
  <template class="MyWindow" parent="GtkWindow">
    <child>
      <object class="GtkBox">
        <child>
          <object class="GtkLabel">
            <property name="label">Hola</property>
            <property name="vexpand">True</property>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="label">Template</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
